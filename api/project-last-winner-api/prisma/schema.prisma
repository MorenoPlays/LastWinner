// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



/*************************/
// Prisma Schema — Plataforma de Torneios (Google OAuth + Brackets + Chats)

// ===================== ENUMS =====================

enum Role {
  USER
  ADMIN
  ORGANIZER
}

enum TournamentStatus {
  DRAFT
  OPEN
  ONGOING
  FINISHED
  CANCELED
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum TournamentMode {
  ONLINE
  PRESENTIAL
}

enum ParticipantStatus {
  REGISTERED
  CHECKED_IN
  ELIMINATED
  WINNER
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
  CANCELED
}

enum TeamRole {
  OWNER
  CAPTAIN
  PLAYER
}

// ===================== USERS =====================

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String?
  avatarUrl     String?
  bio           String?
  country       String?

  role          Role     @default(USER)

  elo           Int      @default(1000)
  wins          Int      @default(0)
  losses        Int      @default(0)

  isVerified    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  oauthAccounts OAuthAccount[]
  tournaments   Tournament[] @relation("OrganizerTournaments")
  participations TournamentParticipant[]
  matches1      Match[] @relation("Player1")
  matches2      Match[] @relation("Player2")
  matchStats    MatchStats[]

  teamsOwned    Team[] @relation("TeamOwner")
  teamMembers   TeamMember[]

  notifications Notification[]
  clips         Clip[]
  GroupChat     GroupChat[]
  GroupChatMember GroupChatMember[]
  groupMessages GroupChatMessage[]
  TournamentMessage TournamentMessage[]
  achievements  UserAchievement[]
}

// ===================== OAUTH =====================

model OAuthAccount {
  id                  String @id @default(uuid())
  userId              String
  provider            String
  providerAccountId   String

  accessToken         String?
  refreshToken        String?

  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===================== GAMES =====================

model Game {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  coverUrl  String?

  tournaments Tournament[]
  clips       Clip[]
}

// ===================== TOURNAMENTS =====================

model Tournament {
  id            String   @id @default(uuid())

  organizerId   String
  gameId        String

  title         String
  description   String?

  format        TournamentFormat
  mode          TournamentMode
  status        TournamentStatus @default(DRAFT)

  maxPlayers    Int

  entryFee      Float   @default(0)
  prizePool     Float   @default(0)

  startDate     DateTime?
  endDate       DateTime?

  bannerUrl     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizer     User @relation("OrganizerTournaments", fields: [organizerId], references: [id])
  game          Game @relation(fields: [gameId], references: [id])

  participants  TournamentParticipant[]
  brackets      Bracket[]
  rewards       TournamentReward[]
  messages      TournamentMessage[]
  groupChats    GroupChat[]
}

// ===================== PARTICIPANTS =====================

model TournamentParticipant {
  id            String @id @default(uuid())

  tournamentId  String
  userId        String

  status        ParticipantStatus @default(REGISTERED)
  finalPosition Int?

  joinedAt      DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  user       User @relation(fields: [userId], references: [id])
}

// ===================== BRACKETS =====================

model Bracket {
  id            String @id @default(uuid())
  tournamentId  String
  type          TournamentFormat

  createdAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  matches    Match[]
}

// ===================== MATCHES =====================

model Match {
  id            String @id @default(uuid())

  bracketId     String

  roundNumber   Int
  matchNumber   Int

  player1Id     String
  player2Id     String

  winnerId      String?
  loserId       String?

  status        MatchStatus @default(PENDING)

  scheduledAt   DateTime?
  finishedAt    DateTime?

  bracket Bracket @relation(fields: [bracketId], references: [id])
  MatchStats MatchStats[]
  player1 User @relation("Player1", fields: [player1Id], references: [id])
  player2 User @relation("Player2", fields: [player2Id], references: [id])
}

// ===================== MATCH STATS =====================

model MatchStats {
  id        String @id @default(uuid())

  matchId   String
  userId    String

  kills     Int @default(0)
  deaths    Int @default(0)
  assists   Int @default(0)
  score     Int @default(0)

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

// ===================== TEAMS =====================

model Team {
  id        String @id @default(uuid())
  name      String
  logoUrl   String?

  ownerId   String

  createdAt DateTime @default(now())

  owner     User @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
}

model TeamMember {
  id        String @id @default(uuid())

  teamId    String
  userId    String

  role      TeamRole @default(PLAYER)

  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// ===================== REWARDS =====================

model TournamentReward {
  id           String @id @default(uuid())

  tournamentId String

  position     Int
  rewardTitle  String?
  amount       Float

  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
}

// ===================== GROUP CHATS =====================

model GroupChat {
  id           String @id @default(uuid())
  name         String
  ownerId      String

  createdAt    DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id])

  members GroupChatMember[]
  messages GroupChatMessage[]

  tournamentId String?
  tournament Tournament? @relation(fields: [tournamentId], references: [id])
}

model GroupChatMember {
  id        String @id @default(uuid())

  groupChatId String
  userId      String

  joinedAt DateTime @default(now())

  groupChat GroupChat @relation(fields: [groupChatId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model GroupChatMessage {
  id          String @id @default(uuid())

  groupChatId String
  userId      String

  message     String

  createdAt   DateTime @default(now())

  groupChat GroupChat @relation(fields: [groupChatId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// ===================== TOURNAMENT CHAT =====================

model TournamentMessage {
  id           String @id @default(uuid())

  tournamentId String
  userId       String

  message      String

  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// ===================== CLIPS =====================

model Clip {
  id        String @id @default(uuid())

  userId    String
  gameId    String

  title     String
  videoUrl  String
  thumbnail String?

  views     Int @default(0)
  likes     Int @default(0)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
}

// ===================== NOTIFICATIONS =====================

model Notification {
  id        String @id @default(uuid())

  userId    String

  title     String
  content   String

  isRead    Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ===================== ACHIEVEMENTS =====================

model Achievement {
  id          String @id @default(uuid())
  title       String
  description  String?
  iconUrl     String?

  users UserAchievement[]
}

model UserAchievement {
  id            String @id @default(uuid())

  userId        String
  achievementId String

  unlockedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])
}

